{
  "name": "factorio-map-webui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "test": "vp test",
    "perf": "FMW_PERF=1 vp test test/render-cost.perf.spec.ts && cat perf-result.txt",
    "check": "vp check --fix",
    "preview:dev": "concurrently -k -n worker,app -c blue,green \"pnpm run preview:worker\" \"pnpm run preview:app\"",
    "preview:worker": "pnpm --filter @fmw/preview-worker exec wrangler dev --var ALLOWED_ORIGIN:http://localhost:5173",
    "preview:app": "VITE_PREVIEW_SERVICE_URL=http://localhost:8787 vp dev --port 5173 --strictPort",
    "preview:test": "pnpm --filter @fmw/preview-worker test && pnpm --filter @fmw/preview-container test",
    "preview:deploy": "pnpm --filter @fmw/preview-worker run deploy",
    "deploy:app": "pnpm build && pnpm --filter @fmw/preview-worker exec wrangler pages deploy dist --cwd ../.. --project-name factoriomapwebui --branch main --commit-dirty=true",
    "deploy": "pnpm run deploy:app"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "zlib-asm": "^1.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
